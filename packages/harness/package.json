{
  "name": "@rulebased/harness",
  "version": "1.4.7",
  "description": "Harness engineering tools for AI agents — audit, init, recommend, eval-log",
  "type": "module",
  "bin": {
    "harness": "dist/cli.js"
  },
  "main": "dist/auditor.js",
